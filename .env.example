# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Sub-caminho de montagem (integração em site maior) ────────────────────────
# Deixe vazio quando rodar como servidor independente (standalone).
# Defina como /rh se este app for montado no site principal via:
#   pai.use('/rh', require('./gerenciador-pastas/server').app)
# Isso ajusta todos os redirects e o helper window.__BASE no frontend.
MOUNT_PATH=

# ── Banco de dados (MySQL local) ──────────────────────────────────────────────
# Crie o banco antes de subir: CREATE DATABASE gerenciador_pastas;
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=gerenciador_pastas

# ── Armazenamento de arquivos (Cloudinary) ────────────────────────────────────
# Sem essas vars os uploads ficam no disco local em public/midia/uploads/ (dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Autenticacao ──────────────────────────────────────────────────────────────
LOGIN_USER=Maria Pateis
LOGIN_PASS=UpConsult@25
